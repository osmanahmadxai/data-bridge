// Prisma schema for Relay's OWN metadata store (saved connections).
//
// NOTE: This models only the application's internal SQLite file. The databases
// users connect TO are accessed through the raw driver adapters in
// @relay/core — an ORM cannot introspect arbitrary, unknown schemas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Connection {
  id                  String   @id
  name                String
  engine              String
  color               String?
  host                String?
  port                Int?
  user                String?
  passwordEnc         String?  @map("password_enc")
  database            String?
  ssl                 Boolean  @default(false)
  connectionStringEnc String?  @map("connection_string_enc")
  optionsJson         String?  @map("options_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("connections")
}
